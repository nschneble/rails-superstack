<%# Admin-only form for broadcasting a global system notification (toast) to
    all connected users via Turbo streams %>

<% content_for :title, t("notifications.title") %>

<%= tag.div class: "w-full my-28" do %>
  <%= form_with(url: notifications_path, scope: :global_notification, class: form_classes) do |form| %>
    <%= tag.h1 t("notifications.form.title"), class: form_title_classes %>

    <%= form.label :message,
                   t("notifications.form.label",
                   max: Notification::MAX_MESSAGE_LENGTH),
                   class: "max-w-[525]" %>
    <%= form.text_area :message,
                       required: true,
                       autofocus: true,
                       placeholder: t("notifications.form.placeholder"),
                       rows: 5,
                       maxlength: Notification::MAX_MESSAGE_LENGTH,
                       class: "max-w-[525]" %>

    <%= form.submit t("notifications.form.submit") %>
  <% end %>
<% end %>
