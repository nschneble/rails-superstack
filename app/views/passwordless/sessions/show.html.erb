<%# This is the Passwordless form where the user inputs the token they received %>

<% content_for :title, t("sign_in.title") %>

<%= tag.div class: "w-full my-28" do %>
  <%= form_with(model: @session, url: url_for(action: "update"), scope: "passwordless", method: "patch", data: { turbo: false, controller: "email" }, class: form_classes) do |form| %>
    <%= tag.h1 t("verification_code.title"), class: form_title_classes %>

    <%# login token %>
    <%= form.label :token, t(".token") %>
    <%= form.text_field :token,
        class: form_input_classes,
        required: true,
        autofocus: true,
        autocomplete: "one-time-code",
        placeholder: t("verification_code.placeholder"),
        data: { "email-target": "input" } %>

    <%# form submission %>
    <%= form.submit t(".confirm"), data: { action: "click->email#submit", "email-target": "button" } %>
  <% end %>
<% end %>
