<%# This is the Passwordless form where the user inputs their email address %>

<% content_for :title, t("sign_in.title") %>

<%= tag.div class: "w-full my-28" do %>
  <% email_field_name = :"passwordless[#{email_field}]" %>

  <%= form_with(model: @session, url: url_for(action: "new"), data: { turbo: "false", controller: "email" }, class: form_classes) do |form| %>
    <%= tag.h1 t("sign_in.title"), class: form_title_classes %>

    <%# email address %>
    <%= form.label email_field_name,
                t("passwordless.sessions.new.email.label"),
                for: "passwordless_#{email_field}" %>
    <%= email_field_tag email_field_name,
                        params.fetch(email_field_name, nil),
                        class: form_input_classes,
                        required: true,
                        autofocus: true,
                        placeholder: t("passwordless.sessions.new.email.placeholder"),
                        data: { "email-target": "input" } %>

    <%# form submission %>
    <%= form.submit t("passwordless.sessions.new.submit"), data: { action: "click->email#submit", "email-target": "button" } %>
  <% end %>
<% end %>
