<%= tag.ul class: "flex flex-col gap-y-3 list-none ml-2" do %>
  <% items.each do |item| %>
    <%= tag.li do %>
      <%= fa_stacked_icon(["square", item.avatar], [current_theme.highlight, current_theme.text]) %>
      <%= tag.span item.rendered_description %>

      <% if item.byline %>
        <%= tag.p item.rendered_byline, class: "ml-[50] text-sm italic" %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
