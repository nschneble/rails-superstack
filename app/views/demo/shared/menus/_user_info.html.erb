<% if current_user %>
  <%= tag.div class: "px-4 py-2 text-xs text-slate-600 select-none" do %>
    <%= tag.p "Signed in as" %>
    <%= tag.p current_user.email, class: "mr-8 font-medium text-slate-700 truncate" %>

    <%= tag.div class: "absolute top-2 right-2" do %>
      <%= pom_subscription_badge(pro: current_user.pro_subscription?) %>
    <% end %>
  <% end %>

  <%= tag.div class: "border-t border-slate-300" %>
<% end %>
