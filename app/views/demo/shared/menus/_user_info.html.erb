<% if current_user %>
  <div class="px-4 py-2 text-xs text-slate-600 select-none">
    <p>Signed in as</p>
    <p class="mr-8 font-medium text-slate-700 truncate"><%= current_user.email %></p>
    <div class="absolute top-2 right-2">
      <%= pom_subscription_badge(pro: current_user.pro_subscription?) %>
    </div>
  </div>

  <div class="border-t border-slate-300"></div>
<% end %>
