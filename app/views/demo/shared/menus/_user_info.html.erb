<% if current_user %>
  <div class="px-4 py-2 text-xs text-slate-600 select-none">
    <span>Signed in as</span>
    <span class="font-medium text-slate-700 break-all"><%= current_user.email %></span>
    <div class="mt-1">
      <% if current_user.subscription&.pro? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">Pro</span>
      <% else %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-200 text-slate-600">Free</span>
      <% end %>
    </div>
  </div>

  <div class="border-t border-slate-300"></div>
<% end %>
