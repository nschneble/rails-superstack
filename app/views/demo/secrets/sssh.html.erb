<% content_for :title, "Secret Page" %>

<%= tag.div class: "w-full sm:ml-11 mt-[76] mb-[52] text-white overflow-y-scroll" do %>
  <%= tag.div class: "max-w-[650] mx-auto" do %>
    <%= tag.h1 "This is a Secret Page!", class: "mx-3 sm:mx-0 mt-8 sm:mt-[50] mb-4 font-semibold text-3xl tracking-tight" %>
    <%= tag.div class: "mx-4 sm:mx-0" do %>
      <%= image_tag "demo/secret_bookcase.jpg", class: "rounded-md", size: "650", alt: "Opened secret door inside library" %>
      <%= tag.p class: "p-1 text-xs text-right" do %>
        Photo by
        <%= link_to "Stefan Steinbauer",
                    "https://unsplash.com/@usinglight",
                    class: "hover:text-amber-400 underline!" %>
        on
        <%= link_to "Unsplash",
                    "https://unsplash.com/photos/opened-secret-door-inside-library-HK8IoD-5zpg",
                    class: "hover:text-amber-400 underline!" %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
