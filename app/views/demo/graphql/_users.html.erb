<%# GraphQL Users query documentation. Shows the /graphql POST request format
    and a copyable cURL command. Requires an auth token %>

<%= fa_stacked_icon(["square", "users"], [current_theme.highlight, current_theme.text]) %>
Users
<%= tag.p class: "ml-[50] -mt-2 mb-2 text-sm italic" do %>
  Requires
  <%= tag.span "authentication", class: "text-amber-200 font-semibold" %>
<% end %>
<%= tag.p class: "ml-[50] mb-1 text-sm" do %>
  <%= link_to "Create API Token",
              settings_api_path,
              class: "hover:text-amber-400 underline!" %>
<% end %>
<%= tag.p class: "ml-[50] mb-1 text-sm" do %>
  <%= link_to "Run User Query with GraphiQL",
              graphiql_path,
              class: "hover:text-amber-400 underline!" %>
<% end %>
<%= tag.p class: "ml-[50] mb-4 text-sm" do %>
  <%= link_to "Inspect Schema",
              graphql_describe_path,
              class: "hover:text-amber-400 underline!" %>
<% end %>
<%= tag.div class: [ "relative mx-12 my-2 bg-slate-900 rounded-sm rounded-tr-md rounded-br-md", current_theme.highlight ] do %>
  <%= tag.pre class: "p-2 pr-[42] text-sm truncate" do %>
    <%= tag.span "POST", class: "text-white select-none" %>
    <%= tag.span do %>
      /graphql<br><br>
      Authorization: Bearer TOKEN<br>
      Content Type: &nbsp;application/json<br>
      Payload Data: &nbsp;{ query: { users { id email } } }<br><br>
      200 Response:<br>
      { data: { users: [<br>
      &nbsp;&nbsp;{ id: 1, email: "user@superstack.dev" },<br>
      &nbsp;&nbsp;{ id: 2, email: "api@superstack.dev" }<br>
      ] } }
    <% end %>
  <% end %>

  <%= pom_copy_to_clipboard align: :right,
                            text: "bin/api-token | xargs -I% curl -s -H 'Content-Type: application/json' -H 'Authorization: %' -X POST http://localhost:3000/graphql -d '{\"query\":\"{ users { id email role } }\"}' | jq",
                            class: "rounded-bl-md rounded-br-none" %>
<% end %>
