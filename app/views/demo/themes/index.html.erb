<%= content_tag :div, class: "w-full sm:ml-11 mt-[76] mb-[52] text-white overflow-y-scroll" do %>
  <%= content_tag :div, class: "max-w-[650] mx-auto px-3 sm:px-0" do %>

    <% if params[:purchased] %>
      <div class="mb-6 p-4 bg-emerald-900/40 border border-emerald-600/40 rounded-lg text-emerald-300">
        <%= t("demo.themes.purchased_notice", name: Demo::ThemePurchase::THEMES.dig(params[:purchased], :name)) %>
      </div>
    <% end %>

    <h1 class="mt-8 sm:mt-[50] mb-2 font-semibold text-3xl tracking-tight">
      <%= t("demo.themes.title") %>
    </h1>
    <p class="text-slate-400 mb-8"><%= t("demo.themes.subtitle") %></p>

    <div class="grid grid-cols-1 gap-6">
      <% @themes.each do |key, theme| %>
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 bg-blue-900/50 border border-slate-600 rounded-xl p-6">
          <div class="flex-1">
            <h2 class="font-semibold text-xl text-white mb-1"><%= theme[:name] %></h2>
            <p class="text-slate-400 text-sm"><%= theme[:description] %></p>
            <p class="text-emerald-400 font-bold mt-2">
              <%= format("$%.2f", theme[:price_cents] / 100.0) %>
            </p>
          </div>

          <div class="shrink-0">
            <% if @purchased_keys.include?(key) %>
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-emerald-900/50 border border-emerald-600/40 text-emerald-300 text-sm font-medium">
                ✓ <%= t("demo.themes.purchased") %>
              </span>
            <% else %>
              <%= form_with url: demo_theme_checkout_path, method: :post do |f| %>
                <%= f.hidden_field :theme_key, value: key %>
                <%= f.submit t("demo.themes.buy_now"),
                    class: "px-6 py-2 rounded-lg bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-semibold transition-colors cursor-pointer" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  <% end %>
<% end %>
