<div class="mx-4 sm:mx-0 mb-4">
  <%= form_with url: demo_mac_guffins_path,
                method: :get,
                data: {
                  controller: "demo--search",
                  turbo_frame: "mac-guffin-search",
                  action: "turbo:submit-end->search#restoreFocus"
                },
                class: "relative" do %>

    <input id="mac-guffin-search-input"
           type="search"
           name="q"
           value="<%= params[:q].presence %>"
           placeholder="Search by name or description"
           autocomplete="off"
           class="w-full px-3 py-2 bg-white text-slate-900 border border-slate-300 rounded-md shadow-md focus:outline-hidden focus:ring-2 focus:ring-amber-400"
           data-action="input->search#submit">
  <% end %>
</div>
