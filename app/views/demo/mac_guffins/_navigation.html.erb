<%# Pagination footer for MacGuffin search results. Shows Pagy nav when
    multiple pages exist, or an empty-state message %>

<% if @mac_guffins.empty? %>
  <%= tag.p "No MacGuffins matched your search", class: "mx-4 sm:mx-0 mt-8 text-sm text-center text-white italic" %>
<% elsif @pagy.pages > 1 %>
  <%= tag.div class: "mx-4 sm:mx-0 mt-4 flex justify-center" do %>
    <%== @pagy.series_nav %>
  <% end %>
<% end %>
