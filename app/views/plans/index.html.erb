<% content_for :title, "Plans — Rails Superstack" %>

<% free_plan = Billing::Plan::FREE %>
<% pro_plan = Billing::Plan::PRO %>

<div class="w-full my-16 px-4">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-white mb-4">Simple, Transparent Pricing</h1>
      <p class="text-slate-400 text-lg">Choose the plan that's right for you.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">

      <%# Free card %>
      <div class="relative flex flex-col bg-blue-900 border border-slate-600 rounded-xl p-8 shadow-xl">
        <div class="mb-6">
          <h2 class="text-2xl font-bold text-white mb-1"><%= free_plan.name %></h2>
          <p class="text-slate-400 text-sm"><%= free_plan.description %></p>
        </div>

        <div class="mb-6">
          <p class="text-4xl font-bold text-white">Free</p>
        </div>

        <ul class="space-y-3 mb-8 flex-grow">
          <% free_plan.features.each do |feature| %>
            <li class="flex items-center gap-2 text-slate-300 text-sm">
              <span class="text-emerald-400">✓</span>
              <%= feature %>
            </li>
          <% end %>
        </ul>

        <div class="mt-auto">
          <% if current_user && !@user_subscription&.pro? %>
            <span class="block w-full text-center py-3 px-4 rounded-lg bg-slate-700 text-slate-400 text-sm font-medium cursor-default">
              Current Plan
            </span>
          <% elsif !current_user %>
            <%= link_to "Get Started", auth_sign_in_path,
                class: "block w-full text-center py-3 px-4 rounded-lg bg-slate-700 hover:bg-slate-600 text-white text-sm font-medium transition-colors no-underline" %>
          <% end %>
        </div>
      </div>

      <%# Pro Yearly card — featured, middle, slightly larger %>
      <div class="relative flex flex-col bg-blue-900 border border-emerald-500 rounded-xl p-8 shadow-xl ring-2 ring-emerald-400 md:-mt-4 md:mb-4">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="bg-emerald-400 text-slate-900 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Most Popular</span>
        </div>

        <div class="mb-6">
          <h2 class="text-2xl font-bold text-white mb-1">Pro <span class="text-emerald-400">Yearly</span></h2>
          <p class="text-slate-400 text-sm"><%= pro_plan.description %></p>
        </div>

        <div class="mb-6">
          <p class="text-4xl font-bold text-white">$96<span class="text-lg font-normal text-slate-400">/year</span></p>
          <p class="text-emerald-400 text-sm mt-1">$8/month — save $48</p>
        </div>

        <ul class="space-y-3 mb-8 flex-grow">
          <% pro_plan.features.each do |feature| %>
            <li class="flex items-center gap-2 text-slate-300 text-sm">
              <span class="text-emerald-400">✓</span>
              <%= feature %>
            </li>
          <% end %>
        </ul>

        <div class="mt-auto">
          <% if @user_subscription&.pro? %>
            <%= button_to billing_portal_path,
                method: :post,
                class: "w-full py-3 px-4 rounded-lg bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-bold transition-colors cursor-pointer" do %>
              Manage Billing
            <% end %>
          <% elsif current_user %>
            <%= form_with url: billing_checkout_path, method: :post, data: { turbo: false } do |f| %>
              <%= f.hidden_field :price_id, value: pro_plan.yearly_stripe_price_id %>
              <%= f.submit "Subscribe Yearly", class: "w-full py-3 px-4 rounded-lg bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-bold transition-colors cursor-pointer" %>
            <% end %>
          <% else %>
            <%= link_to "Get Started", auth_sign_in_path,
                class: "block w-full text-center py-3 px-4 rounded-lg bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-bold transition-colors no-underline" %>
          <% end %>
        </div>
      </div>

      <%# Pro Monthly card %>
      <div class="relative flex flex-col bg-blue-900 border border-slate-600 rounded-xl p-8 shadow-xl">
        <div class="mb-6">
          <h2 class="text-2xl font-bold text-white mb-1">Pro <span class="text-slate-400">Monthly</span></h2>
          <p class="text-slate-400 text-sm"><%= pro_plan.description %></p>
        </div>

        <div class="mb-6">
          <p class="text-4xl font-bold text-white">$12<span class="text-lg font-normal text-slate-400">/month</span></p>
        </div>

        <ul class="space-y-3 mb-8 flex-grow">
          <% pro_plan.features.each do |feature| %>
            <li class="flex items-center gap-2 text-slate-300 text-sm">
              <span class="text-emerald-400">✓</span>
              <%= feature %>
            </li>
          <% end %>
        </ul>

        <div class="mt-auto">
          <% if @user_subscription&.pro? %>
            <%= button_to billing_portal_path,
                method: :post,
                class: "w-full py-3 px-4 rounded-lg bg-slate-600 hover:bg-slate-500 text-white text-sm font-bold transition-colors cursor-pointer" do %>
              Manage Billing
            <% end %>
          <% elsif current_user %>
            <%= form_with url: billing_checkout_path, method: :post, data: { turbo: false } do |f| %>
              <%= f.hidden_field :price_id, value: pro_plan.monthly_stripe_price_id %>
              <%= f.submit "Subscribe Monthly", class: "w-full py-3 px-4 rounded-lg bg-slate-600 hover:bg-slate-500 text-white text-sm font-bold transition-colors cursor-pointer" %>
            <% end %>
          <% else %>
            <%= link_to "Get Started", auth_sign_in_path,
                class: "block w-full text-center py-3 px-4 rounded-lg bg-slate-600 hover:bg-slate-500 text-white text-sm font-bold transition-colors no-underline" %>
          <% end %>
        </div>
      </div>

    </div>

  </div>
</div>
