<%# Single API token row: name, last-used date, and a revoke (delete) button.
    Rendered as a collection in ./_api.html.erb. %>
<%# locals: (api_token:) %>

<%= tag.div class: "flex p-3 pr-1 bg-slate-100 text-slate-900 rounded-md", id: dom_id(api_token) do %>
  <%= tag.p class: "flex-1 leading-none select-none" do %>
    <%= tag.span api_token.name, class: "font-semibold" %>
    <%= tag.span api_token.format_last_used_at, class: "pl-[1] text-slate-600 text-xs" %>
  <% end %>

  <%= form_with url: settings_revoke_api_token_path(api_token),
                method: :delete,
                class: "flex-none",
                data: {
                  turbo_confirm: t("settings.api_tokens.confirm.destroy", name: api_token.name)
                } do |revoke_form| %>

    <%= revoke_form.button type: "submit", class: "group cursor-pointer" do %>
      <%= fa_stacked_icon(
        ["square", "trash-can"],
        [
          "text-pink-800 group-hover:text-pink-900 group-active:text-pink-950",
          "text-white group-active:text-slate-100"
        ]
      ) %>
    <% end %>
  <% end %>
<% end %>
