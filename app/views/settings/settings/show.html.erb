<%# Settings page with a Turbo frame-driven tab UI. The `tab` local comes from
    the controller and determines which partial to render. Tabs include
    profile, api, and billing. Each tab url updates via Turbo navigate %>

<% content_for :title, t("settings.title") %>

<%= tag.div class: "w-full my-28" do %>
  <%= turbo_frame_tag "settings", data: { turbo_action: "replace" } do %>
    <%= tag.nav role: "tablist", class: "flex max-w-[650] mx-auto my-2 px-2 space-x-4" do %>
      <%= pom_tab_button(icon: "user", tab: :profile, active: tab == "profile", path: settings_profile_path) %>
      <%= pom_tab_button(icon: "key", tab: :api, active: tab == "api", path: settings_api_path) %>
      <%= pom_tab_button(icon: "credit-card", tab: :billing, active: tab == "billing", path: settings_billing_path) %>
    <% end %>

    <%= render tab %>
  <% end %>
<% end %>
