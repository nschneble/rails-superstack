<div class="w-full my-28">
  <%= turbo_frame_tag "settings", data: { turbo_action: "advance" } do %>
    <nav role="tablist" class="flex max-w-[650] mx-auto my-2 px-2 space-x-4">
      <%= pom_tab_button(icon: "user", tab: :profile, active: @current_settings_tab == :profile, path: settings_profile_path) %>
      <%= pom_tab_button(icon: "key", tab: :api, active: @current_settings_tab == :api, path: settings_api_path) %>
    </nav>

    <%= render partial: @current_settings_tab.to_s %>
  <% end %>
</div>
