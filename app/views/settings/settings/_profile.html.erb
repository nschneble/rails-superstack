<%# Profile settings tab. Includes the email change form. Uses
    @email_change_request and `current_user`. A pending request disables the
    input and shows the in-flight new email %>

<%= form_with url: create_email_change_path,
              data: {
                turbo: "false",
                controller: "email"
              },
              id: "settings-panel-profile",
              aria_labelledby: "settings-tab-profile",
              role: "tabpanel",
              class: form_classes do |form| %>

  <%= tag.h1 t("settings.user_profile.title"), class: form_title_classes %>

  <%= form.label :new_email, t("settings.user_profile.label") %>
  <%= form.email_field :new_email,
                       placeholder: t("settings.user_profile.placeholder"),
                       value: @email_change_request&.new_email.presence || current_user.email,
                       required: true,
                       autofocus: true,
                       disabled: @email_change_request.present?,
                       data: {
                         action: "input->email#toggle",
                         email_current_email_param: current_user.email,
                         email_target: "input"
                       } %>

  <%= form.submit t("settings.user_profile.submit"),
                  disabled: true,
                  data: {
                    action: "click->email#submit",
                    email_target: "button"
                  } %>
<% end %>
