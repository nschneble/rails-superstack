<%# Post-Stripe checkout success page. The `redirect` Stimulus controller
    auto-redirects to billing settings after a short delay %>

<% content_for :title, t("billing.subscriptions.success.page_title") %>

<%= tag.div class: "w-full my-28",
            data: {
              controller: "redirect",
              redirect_url_value: settings_billing_path
            } do %>

  <%= tag.div class: form_classes do %>
    <%= tag.h1 fas_icon("champagne-glasses"), class: form_title_classes %>
    <%= tag.h1 t("billing.subscriptions.success.title"), class: form_title_classes %>

    <%= tag.p t("billing.subscriptions.success.description"), class: form_label_classes %>
    <%= tag.p t("billing.subscriptions.success.redirect"), class: [ form_label_classes, "mt-2 mb-8" ] %>

    <%= pom_button(path: settings_billing_path, method: :get) do %>
      <%= t("billing.subscriptions.success.button") %>
    <% end %>
  <% end %>
<% end %>
