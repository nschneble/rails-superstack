<% content_for :title, t("billing.subscriptions.success.page_title") %>

<%= tag.div class: "w-full my-28",
            data: {
              controller: "redirect",
              redirect_url_value: settings_billing_path
            } do %>

  <%= tag.div class: CustomFormBuilder::FORM_CLASSES do %>
    <%= tag.h1 fas_icon("champagne-glasses"), class: CustomFormBuilder::TITLE_CLASSES %>
    <%= tag.h1 t("billing.subscriptions.success.title"), class: CustomFormBuilder::TITLE_CLASSES %>

    <%= tag.p t("billing.subscriptions.success.description"), class: CustomFormBuilder::LABEL_CLASSES %>
    <%= tag.p t("billing.subscriptions.success.redirect"), class: [ CustomFormBuilder::LABEL_CLASSES, "mt-2 mb-8" ] %>

    <%= pom_button(path: settings_billing_path, method: :get) do %>
      <%= t("billing.subscriptions.success.button") %>
    <% end %>
  <% end %>
<% end %>
