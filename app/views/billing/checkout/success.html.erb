<% content_for :title, "Subscription Confirmed — Rails Superstack" %>

<div class="w-full my-28 px-4"
     data-controller="redirect"
     data-redirect-url-value="<%= settings_billing_path %>"
     data-redirect-delay-value="5000">
  <div class="max-w-lg mx-auto text-center">
    <div class="bg-blue-900 border border-slate-600 rounded-xl p-10 shadow-xl">
      <div class="text-5xl mb-6">🎉</div>
      <h1 class="text-3xl font-bold text-white mb-4 tracking-tight">You're all set!</h1>
      <p class="text-slate-400 mb-2">
        Your subscription is being activated. This usually takes just a moment.
      </p>
      <p class="text-slate-500 text-sm mb-8">
        Redirecting you to settings in a few seconds…
      </p>
      <%= link_to "Go to Settings",
          settings_billing_path,
          class: "inline-block py-3 px-8 rounded-lg bg-emerald-500 hover:bg-emerald-600 text-white font-semibold transition-colors" %>
    </div>
  </div>
</div>
