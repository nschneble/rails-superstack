<%= tag.button **merge_options(default_options, extra_options) do %>
  <% if helpers.font_awesome_available? %>
    <%= tag.i class: "fa-solid fa-copy transition-all duration-100", data: { clipboard_target: "icon" } %>
  <% else %>
    <%= tag.span "📋", class: "transition-all duration-100", data: { clipboard_target: "icon" } %>
  <% end %>

  <% if content.present? %>
    <%= tag.span content, class: "ml-1" %>
  <% end %>

  <%= tag.span class: "absolute -top-8 left-1/2 -translate-x-1/2 z-10 bg-slate-800 text-white text-xs rounded px-2 py-1 whitespace-nowrap pointer-events-none opacity-0 translate-y-1 shadow-lg transition-all duration-200",
               data: { clipboard_target: "tooltip" } do %>
    <%= tag.span "Copy to clipboard", data: { clipboard_label: "" } %>
    <%= tag.span class: "absolute left-1/2 top-full -translate-x-1/2 -mt-1 w-2 h-2 bg-slate-800 rotate-45 shadow-lg",
                 aria: { hidden: "true" } %>
  <% end %>
<% end %>
